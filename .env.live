# =====================================================================
# LIVE CONFIG — Phase 23 minimum risk, balance ~$56
# Last updated: 2026-04-09
# =====================================================================

# =====================================================================
# STRATEGY PRESET
# =====================================================================
ACTIVE_STRATEGY=ORDER_BOOK_IMBALANCE

# =====================================================================
# OPERATING MODE — LIVE
# =====================================================================
SIMULATION_MODE=false
TEST_MODE=false
DRY_RUN=false
PRODUCT_TEST_MODE=false
ENABLE_SIGNAL=true
PAPER_TRADING_ENABLED=false

AUTO_REDEEM=true
REDEEM_INTERVAL_MS=30000

# =====================================================================
# OBI ENGINE — sole entry engine
# =====================================================================
OBI_ENGINE_ENABLED=true
OBI_SHADOW_MODE=false

# --- Entry filters ---
OBI_THIN_THRESHOLD_USD=250
OBI_MIN_LIQUIDITY_USD=150
OBI_ENTRY_IMBALANCE_RATIO=0.40
OBI_EXIT_REBALANCE_RATIO=0.65
OBI_KEEP_STRONGER_LEG_PCT=0.50

# --- Sizing (Phase 23: 7 shares = ~$2.80 per trade at 0.40) ---
OBI_ENTRY_SHARES=7
OBI_MAX_POSITION_SHARES=7
OBI_MAX_RISK_PER_TRADE_PCT=0.25

# --- Price range ---
OBI_MIN_ENTRY_PRICE=0.30
OBI_MAX_ENTRY_PRICE=0.50

# --- CLOB minimums ---
OBI_MIN_ENTRY_NOTIONAL_USD=3.0
OBI_CLOB_MIN_NOTIONAL_USD=1.0
OBI_CLOB_MIN_SHARES=6

# --- Slot timing ---
OBI_SLOT_WARMUP_MS=30000
OBI_STOP_ENTRY_BEFORE_END_MS=45000
OBI_CANCEL_ALL_BEFORE_END_MS=20000
OBI_COOLDOWN_MS=8000

# --- Exit ---
OBI_SCALP_EXIT_EDGE=0.08
OBI_MM_ASK_ENABLED=true
OBI_MM_ASK_SPREAD_TICKS=0.015
OBI_MM_BID_OPPOSITE_ENABLED=false
OBI_MM_BID_OPPOSITE_FACTOR=0.25

# --- Safety ---
OBI_AGGRESSIVE_ENTRY=false
OBI_HARD_STOP_USD=2.0
OBI_IMBALANCE_COLLAPSE_RATIO=1.5
OBI_LOSING_EXIT_COOLDOWN_MS=300000
OBI_LOSING_EXIT_COOLDOWN_BY_COIN_MS=300000
OBI_PREFLIGHT_BALANCE_CHECK=true

# --- Binance gate (STRICT) ---
OBI_BINANCE_GATE_ENABLED=true
OBI_BINANCE_RUNAWAY_ABS_PCT=0.30
OBI_BINANCE_CONTRA_ABS_PCT=0.15
OBI_BINANCE_REQUIRE_ALIGNMENT=true

# --- Compounding (dormant until $200) ---
OBI_COMPOUND_THRESHOLD_USD=200

# =====================================================================
# DYNAMIC COMPOUNDING
# =====================================================================
COMPOUNDING_ENABLED=true
COMPOUNDING_GLOBAL_EXPOSURE_PCT=0.80
COMPOUNDING_MAX_SLOT_EXPOSURE_PCT=0.50

# =====================================================================
# LAYERS — all off except OBI
