ORDER_BOOK_IMBALANCE_ENABLED=true
OBI_SHADOW_MODE=false
OBI_THIN_THRESHOLD_USD=8
OBI_MIN_LIQUIDITY_USD=500
OBI_ENTRY_IMBALANCE_RATIO=0.20
OBI_EXIT_REBALANCE_RATIO=0.65
OBI_KEEP_STRONGER_LEG_PCT=0.50
OBI_MAX_ENTRY_PRICE=0.49
OBI_MIN_SHARES=6
OBI_MAX_SHARES=6
OBI_MAX_POSITION_SHARES=12
OBI_COOLDOWN_MS=5000
OBI_HARD_STOP_USD=3.0
OBI_STOP_ENTRY_BEFORE_END_MS=60000
