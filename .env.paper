# =====================================================================
# PAPER TRADING CONFIG — All strategies, all coins, $100 virtual balance
# =====================================================================
# Zero real money risk. Realistic fill simulation against live orderbooks.
# Maker orders queue until book crosses price (0% fee).
# Taker orders fill instantly via book walk (2% fee).
# =====================================================================


# =====================================================================
# STRATEGY PRESET
# =====================================================================
ACTIVE_STRATEGY=CURRENT_SNIPER


# =====================================================================
# OPERATING MODE — PAPER
# =====================================================================
SIMULATION_MODE=false
TEST_MODE=false
DRY_RUN=false
PRODUCT_TEST_MODE=false
ENABLE_SIGNAL=true
PAPER_TRADING_ENABLED=true
PAPER_TRADING_INITIAL_BALANCE=100
PAPER_TRADING_MAKER_FEE_RATE=0
PAPER_TRADING_TAKER_FEE_RATE=0.02
PAPER_TRADING_MAKER_ORDER_TTL_MS=300000

AUTO_REDEEM=false


# =====================================================================
# DYNAMIC COMPOUNDING
# =====================================================================
COMPOUNDING_ENABLED=true
COMPOUNDING_GLOBAL_EXPOSURE_PCT=0.80
COMPOUNDING_MAX_SLOT_EXPOSURE_PCT=0.50


# =====================================================================
# ACTIVE LAYERS — ALL ON
# =====================================================================
ENTRY_STRATEGY=LEGACY
SNIPER_MODE_ENABLED=true
MARKET_MAKER_MODE=true
DYNAMIC_QUOTING_ENABLED=true
LOTTERY_LAYER_ENABLED=false

PAIRED_ARB_ENABLED=false
PAIRED_ARB_ASYNC_ENABLED=false
LATENCY_MOMENTUM_ENABLED=false

MM_AUTO_ACTIVATE_AFTER_SNIPER=true
MM_AUTONOMOUS_QUOTES=false
LAYER_CONFLICT_RESOLUTION=BLOCK


# =====================================================================
# OBI ENGINE — Order Book Imbalance
