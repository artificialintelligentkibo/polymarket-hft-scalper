SIMULATION_MODE=true
ENABLE_SIGNAL=true

AUTH_MODE=EOA
SIGNATURE_TYPE=0
SIGNER_PRIVATE_KEY=
FUNDER_ADDRESS=

RPC_URL=https://polygon.drpc.org
POLYMARKET_GEO_TOKEN=

CLOB_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com

ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_REFRESH_MS=1500
MARKET_SCAN_INTERVAL_MS=2500
MAX_CONCURRENT_MARKETS=6
MARKET_QUERY_LIMIT=80
ONLY_FIVE_MINUTE_MARKETS=true

ENTRY_BUY_EDGE=0.018
ENTRY_SELL_EDGE=0.015
TRAILING_TAKE_PROFIT=0.012
HARD_STOP_LOSS=0.025
MIN_SHARES=8
MAX_SHARES=35
MAX_NET_YES=65
MAX_NET_NO=-75
MIN_LIQUIDITY_USD=500
SIZE_LIQUIDITY_CAP_USD=2500
EXIT_BEFORE_END_MS=20000

SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=GTC
ORDER_TYPE_FALLBACK=GTC
POST_ONLY=false

LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIRECTORY=logs
