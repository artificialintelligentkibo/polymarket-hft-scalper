# ==============================================================
#   POLYMARKET HFT SCALPER - Environment Configuration
# ==============================================================
#
# SETUP GUIDE:
# 1. Copy this file: cp .env.example .env
# 2. Follow the steps below to fill in credentials
# 3. Run: npm start

# ==============================================================
# SECTION 1: AUTHENTICATION (REQUIRED)
# ==============================================================
#
# HOW TO FIND YOUR ADDRESSES:
#   FUNDER_ADDRESS -> Polymarket.com -> Settings -> Profile -> "Address" field
#   SIGNER address -> Your MetaMask/browser wallet address (the one you login with)
#   These are DIFFERENT addresses. Funder is the proxy wallet, Signer is your EOA.
#
# HOW TO DETERMINE SIGNATURE_TYPE:
#   Email/Google login (Magic Link) -> SIGNATURE_TYPE=1
#   MetaMask/Rabby/browser wallet   -> SIGNATURE_TYPE=2
#
AUTH_MODE=PROXY
SIGNATURE_TYPE=2

# Your MetaMask private key (Account Details -> Show Private Key)
# The address derived from this key must match the "Signer Address"
# shown on Polymarket -> Settings -> Relayer API Keys
SIGNER_PRIVATE_KEY=

# Proxy wallet address from Polymarket -> Settings -> Profile -> "Address"
FUNDER_ADDRESS=

# --- CLOB API Credentials (for trading: orders, cancel, fills) ---
#
# Generate these ONCE using Python:
#   python3 -m venv /tmp/poly && source /tmp/poly/bin/activate
#   pip install py-clob-client
#   python3 -c "
#   from py_clob_client.client import ClobClient
#   c = ClobClient('https://clob.polymarket.com',
#       key='YOUR_SIGNER_PRIVATE_KEY',
#       chain_id=137,
#       signature_type=2,  # Use 1 for Magic Link, 2 for MetaMask
#       funder='YOUR_FUNDER_ADDRESS')
#   creds = c.create_or_derive_api_creds()
#   print(f'POLYMARKET_API_KEY={creds.api_key}')
#   print(f'POLYMARKET_API_SECRET={creds.api_secret}')
#   print(f'POLYMARKET_API_PASSPHRASE={creds.api_passphrase}')
#   "
#
# WARNING: Running create_or_derive_api_creds() again will INVALIDATE
# the previous credentials. Only run it once and save the output.
#
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Signer address (derived from SIGNER_PRIVATE_KEY, NOT the funder)
# Verify: python3 -c "from eth_account import Account; print(Account.from_key('YOUR_KEY').address)"
POLYMARKET_API_KEY_ADDRESS=

# --- Relayer API Credentials (for gasless on-chain: redeem, approve) ---
#
# WHERE TO FIND:
#   Polymarket.com -> Settings -> Relayer API Keys
#   Click on the key to copy the full value
#   "Signer Address" on that page = POLYMARKET_RELAYER_KEY_ADDRESS
#
# NOTE: These are DIFFERENT from CLOB credentials above!
#
POLYMARKET_RELAYER_KEY=
POLYMARKET_RELAYER_KEY_ADDRESS=

# ==============================================================
# SECTION 2: OPERATING MODE
# ==============================================================
#
# For simulation (paper trading, no real orders):
#   SIMULATION_MODE=true, DRY_RUN=true
#
# For live trading:
#   SIMULATION_MODE=false, DRY_RUN=false, TEST_MODE=false
#
# For product test (1 slot, tiny size, real orders):
#   PRODUCT_TEST_MODE=true, AUTO_REDEEM=true
#
SIMULATION_MODE=true
TEST_MODE=false
DRY_RUN=true
PRODUCT_TEST_MODE=false
ENABLE_SIGNAL=true

# === STRATEGY MODULE =================================================
# High-level strategy preset switcher. Applied on top of all other flags.
#
# CURRENT_SNIPER       → default. Existing Binance-led sniper + lottery + MM
#                        behaviour. Zero changes from historical config.
# PAIRED_ARBITRAGE     → googoogaga23-style YES+NO arbitrage. Auto-enables
#                        PAIRED_ARB_ENABLED, ENTRY_STRATEGY=PAIRED_ARBITRAGE,
#                        POST_ONLY_ONLY=true and DISABLES sniper, MM, lottery,
#                        and latency-momentum so the bot only trades paired
#                        arb opportunities with limit orders.
# ORDER_BOOK_IMBALANCE → vague-sourdough-style placeholder. Not implemented
#                        yet — falls back to CURRENT_SNIPER with a warning.
#
# Switching strategies: change ACTIVE_STRATEGY and restart. All other flags
# below remain authoritative when ACTIVE_STRATEGY=CURRENT_SNIPER.
ACTIVE_STRATEGY=CURRENT_SNIPER
# =====================================================================

# === ORDER BOOK IMBALANCE FILTER ======================================
# Optional gate for Layer 2 (Market Making) activation, inspired by the
# vague-sourdough article (https://x.com/retrovalix/status/...).
#
# When ORDER_BOOK_IMBALANCE_ENABLED=true, MM will activate after a sniper
# entry ONLY IF the orderbook on the trigger outcome shows a meaningful
# liquidity imbalance (thin side thin enough AND total top liquidity
# deep enough AND thin/thick ratio below entry threshold).
#
# Backward compatibility: when disabled (default), MM activation behaves
# exactly as before and the filter is a no-op.
#
# Tuning defaults match the "vague-sourdough" style: expect markets with
# ~$500+ top-of-book liquidity and <$8 on the thin side.
ORDER_BOOK_IMBALANCE_ENABLED=false
# Thin-side depth (USD) below which the book qualifies as imbalanced.
OBI_THIN_THRESHOLD_USD=8
# Minimum total top-of-book liquidity (bid + ask USD) required to act.
OBI_MIN_LIQUIDITY_USD=500
# Entry ratio (thin / thick). MM activates when ratio <= this value.
OBI_ENTRY_IMBALANCE_RATIO=0.35
# Exit ratio. Active MM leg should rebalance when ratio climbs back >=.
OBI_EXIT_REBALANCE_RATIO=0.65
# On rebalance, keep this fraction of the stronger leg (0 = flatten all).
OBI_KEEP_STRONGER_LEG_PCT=0.50
# Shadow mode: filter logs "would allow / would block" but never blocks.
# Useful for A/B testing against live CURRENT_SNIPER behaviour.
OBI_SHADOW_MODE=false
# =====================================================================

# === OBI ENGINE (standalone Layer 1 — vague-sourdough style) ==========
# Master switch. When ACTIVE_STRATEGY=ORDER_BOOK_IMBALANCE this is auto-set
# to true. Otherwise defaults to false (backward compatible).
OBI_ENGINE_ENABLED=false

# Entry parameters (tuned from vague-sourdough on-chain data)
OBI_ENTRY_SHARES=8
OBI_MAX_POSITION_SHARES=20
OBI_MIN_ENTRY_PRICE=0.04
OBI_MAX_ENTRY_PRICE=0.50
OBI_COOLDOWN_MS=15000
OBI_SLOT_WARMUP_MS=5000
OBI_STOP_ENTRY_BEFORE_END_MS=90000
OBI_CANCEL_ALL_BEFORE_END_MS=20000

# Exit parameters
OBI_SCALP_EXIT_EDGE=0.08

# Layer 2: MM quoting after entry fill
OBI_MM_ASK_ENABLED=true
OBI_MM_ASK_SPREAD_TICKS=0.015
OBI_MM_BID_OPPOSITE_ENABLED=false
OBI_MM_BID_OPPOSITE_FACTOR=0.25

# Safety
OBI_AGGRESSIVE_ENTRY=false
# =====================================================================

ENTRY_STRATEGY=LEGACY
PAIRED_ARB_ENABLED=false
LATENCY_MOMENTUM_ENABLED=false
PAPER_TRADING_ENABLED=false
AUTO_REDEEM=false
REDEEM_INTERVAL_MS=30000

# ==============================================================
# SECTION 2B: MARKET MAKER MODE (2026)
# ==============================================================
# Leave both flags false to preserve the legacy dual-sided scalper.
# Enable both only after validating quote management in PRODUCT_TEST_MODE.
# Dual-sided quoting places BID and ASK quotes around fair value to collect spread.
MARKET_MAKER_MODE=false
DYNAMIC_QUOTING_ENABLED=false
MM_AUTONOMOUS_QUOTES=true
MM_ALWAYS_QUOTE=false
MM_QUOTE_SHARES=5
MM_MAX_GROSS_EXPOSURE_USD=15
MM_MAX_NET_DIRECTIONAL=10
MM_MIN_SPREAD_TICKS=2
MM_REQUIRE_FAIR_VALUE=true
MM_MIN_BOOK_DEPTH_USD=3
MM_MAX_CONCURRENT_MARKETS=4
MM_INVENTORY_SKEW_FACTOR=0.3
MM_MIN_EDGE_AFTER_FEE=0.005
POST_ONLY_ONLY=true
QUOTING_INTERVAL_MS=150
MAX_IMBALANCE_PERCENT=35
QUOTING_SPREAD_TICKS=2
REBALANCE_ON_IMBALANCE=true
DEEP_BINANCE_MODE=false
BINANCE_WS_ENABLED=true
BINANCE_DEPTH_LEVELS=20
BINANCE_FUNDING_WEIGHT=0.3
MIN_BINANCE_SPREAD_THRESHOLD=0.004
DYNAMIC_SPREAD_VOL_FACTOR=1.5
BINANCE_FAIR_VALUE_WEIGHT=0.7
POLYMARKET_FAIR_VALUE_WEIGHT=0.2

# ==============================================================
# SECTION 2C: SNIPER MODE (Binance-led aggressive taker entries)
# ==============================================================
# Sniper mode watches Binance for fast directional moves, then buys the
# winning side on Polymarket before repricing completes. Keep it disabled
# by default for full backward compatibility and enable only after paper
# testing or PRODUCT_TEST_MODE validation.
SNIPER_MODE_ENABLED=false
SNIPER_MIN_BINANCE_MOVE_PCT=0.10
SNIPER_STRONG_BINANCE_MOVE_PCT=0.30
SNIPER_MIN_EDGE_AFTER_FEES=0.01
SNIPER_TAKER_FEE_PCT=0.0315
SNIPER_MAX_ENTRY_PRICE=0.55
SNIPER_MIN_ENTRY_PRICE=0.03
SNIPER_MIN_PM_LAG=0.03
SNIPER_BASE_SHARES=6
SNIPER_STRONG_SHARES=12
SNIPER_MAX_POSITION_SHARES=20
SNIPER_MAX_CONCURRENT_SAME_DIRECTION=2
SNIPER_COOLDOWN_MS=3000
SNIPER_SLOT_WARMUP_MS=15000
SNIPER_EXIT_BEFORE_END_MS=30000
SNIPER_MAX_HOLD_MS=0
SNIPER_SCALP_EXIT_EDGE=0.08
SNIPER_STOP_LOSS_PCT=0.15
SNIPER_BREAK_EVEN_EDGE=0.04
SNIPER_VELOCITY_WINDOW_MS=5000
SNIPER_MIN_VELOCITY_PCT_PER_SEC=0.005
SNIPER_VOLATILITY_SCALE=0.003

# ==============================================================
# SECTION 2D: MARKET REGIME FILTER (sniper entry quality filter)
# ==============================================================
# Classifies Binance price action as TRENDING or RANGING.
# When RANGING, sniper entries are blocked to avoid choppy losses.
# Uses existing Binance WebSocket data — zero latency, no external deps.
REGIME_FILTER_ENABLED=false
# Lookback window for regime analysis (default 5 min = 300000ms)
REGIME_FILTER_LOOKBACK_MS=300000
# Micro-bar aggregation interval (default 10 sec = 10000ms)
REGIME_FILTER_BAR_INTERVAL_MS=10000
# Min price samples before regime can be assessed (default 20)
REGIME_FILTER_MIN_SAMPLES=20
# Directional efficiency threshold (0..1). Higher = stricter. Default 0.4
REGIME_FILTER_EFFICIENCY_THRESHOLD=0.4
# Normalized ATR threshold. Lower = blocks more low-vol conditions. Default 0.0003
REGIME_FILTER_ATR_THRESHOLD=0.0003

# ==============================================================
# SECTION 3: MARKET SELECTION
# ==============================================================
COINS_TO_TRADE=BTC,SOL,XRP,ETH
FILTER_5MIN_ONLY=true
MIN_LIQUIDITY_USD=500
WHITELIST_CONDITION_IDS=

# ==============================================================
# SECTION 4: STRATEGY PARAMETERS
# ==============================================================
#
# ENTRY_STRATEGY modes:
#   LEGACY            -> existing combined/extreme/fair-value entries
#   PAIRED_ARBITRAGE  -> market-neutral YES+NO paired entries
#   LATENCY_MOMENTUM  -> Binance-led cheap-side taker entries
#   ALL               -> run all entry engines together
#
MIN_COMBINED_DISCOUNT=0.01
EXTREME_SELL_THRESHOLD=0.93
EXTREME_BUY_THRESHOLD=0.04
FAIR_VALUE_BUY_THRESHOLD=0.005
FAIR_VALUE_SELL_THRESHOLD=0.005
TRAILING_TAKE_PROFIT=0.012
HARD_STOP_LOSS=0.025
HARD_STOP_COOLDOWN_MS=15000
MAX_DRAWDOWN_USDC=-15

# --- Paired arbitrage (YES + NO < 1.00 minus fees) ---
PAIRED_ARB_MIN_NET_EDGE=0.02
PAIRED_ARB_MAX_PAIR_COST=0.97
PAIRED_ARB_TARGET_BALANCE_RATIO=1.0
PAIRED_ARB_BALANCE_TOLERANCE=0.15
PAIRED_ARB_MAX_PER_SIDE=200
PAIRED_ARB_MIN_SHARES=20
PAIRED_ARB_MAX_SHARES=80
PAIRED_ARB_COOLDOWN_MS=5000
PAIRED_ARB_REQUIRE_BOTH_LIQUIDITY=true
PAIRED_ARB_MIN_DEPTH_USD=3
PAIRED_ARB_ASYNC_ENABLED=true
PAIRED_ARB_ASYNC_MAX_ENTRY_PRICE=0.45
PAIRED_ARB_ASYNC_MIN_EDGE=0.01
PAIRED_ARB_ASYNC_MAX_WAIT_MS=180000

# --- Latency momentum (Binance move before PM reprices) ---
LATENCY_MOMENTUM_MIN_MOVE_PCT=0.30
LATENCY_MOMENTUM_STRONG_MOVE_PCT=0.50
LATENCY_MOMENTUM_MAX_ENTRY_WINDOW_MS=120000
LATENCY_MOMENTUM_MAX_PM_LAG_PCT=0.10
LATENCY_MOMENTUM_PM_MOVE_SENSITIVITY=0.10
LATENCY_MOMENTUM_MIN_ENTRY_PRICE=0.01
LATENCY_MOMENTUM_MAX_ENTRY_PRICE=0.15
LATENCY_MOMENTUM_BASE_SHARES=30
LATENCY_MOMENTUM_STRONG_SHARES=60
LATENCY_MOMENTUM_MAX_POSITION_SHARES=100
LATENCY_MOMENTUM_COOLDOWN_MS=10000
LATENCY_MOMENTUM_INVERT_SIGNAL=false

# --- Paper trading ---
PAPER_TRADING_INITIAL_BALANCE=100
PAPER_TRADING_LATENCY_MIN_MS=400
PAPER_TRADING_LATENCY_MAX_MS=1500
# For MM paper testing, a slightly higher passive fill rate can be useful.
PAPER_TRADING_FILL_PROB_PASSIVE=0.40
PAPER_TRADING_FILL_PROB_IMPROVE=0.65
PAPER_TRADING_FILL_PROB_CROSS=0.95
PAPER_TRADING_MAX_SLIPPAGE_TICKS=2
PAPER_TRADING_SIZE_IMPACT_FACTOR=0.5
PAPER_TRADING_PARTIAL_FILLS=true
PAPER_TRADING_MIN_FILL_RATIO=0.30
PAPER_TRADING_TRADE_LOG=./reports/paper-trades.jsonl

# --- EV + Kelly filtering ---
EV_KELLY_ENABLED=false
EV_MIN_THRESHOLD=0.005
EV_MIN_THRESHOLD_HIGH_FEE=0.008
KELLY_FRACTION=0.85
MAX_BANKROLL_PER_TRADE=0.20
PREFER_MAKER_ORDERS=true
DEFAULT_TAKER_FEE=0.02
HIGH_FEE_TAKER_FEE=0.0315

# === BAYESIAN FAIR VALUE SMOOTHING ===
# EMA smoothing on calculated fair value to reduce orderbook noise.
# alpha=1.0 = no smoothing (raw value), alpha=0.35 = 65% weight to history.
BAYESIAN_FV_ENABLED=false
BAYESIAN_FV_ALPHA=0.35

# ==============================================================
# SECTION 5: POSITION SIZING
# ==============================================================
MIN_SHARES=8
MAX_SHARES=35
BASE_ORDER_SHARES=12
MAX_NET_YES=200
MAX_NET_NO=250
INVENTORY_IMBALANCE_THRESHOLD=90
INVENTORY_REBALANCE_FRACTION=0.45

# ==============================================================
# SECTION 5b: DYNAMIC COMPOUNDING (balance-aware sizing)
# ==============================================================
# Master switch — when false, all sizing uses static config values (unchanged)
COMPOUNDING_ENABLED=false
# Fraction of bankroll for Layer 1 base size (0.8% = 0.008)
COMPOUNDING_BASE_RISK_PCT=0.008
# Max total exposure per market slot as fraction of bankroll (15%)
COMPOUNDING_MAX_SLOT_EXPOSURE_PCT=0.15
# Dynamic global max exposure as fraction of bankroll (35%)
COMPOUNDING_GLOBAL_EXPOSURE_PCT=0.35
# Layer scaling multipliers (Layer 1=1x, Layer 2=1.5x, ..., Layer 6=3.5x)
COMPOUNDING_LAYER_MULTIPLIERS=1.0,1.5,2.0,2.5,3.0,3.5
# If daily drawdown exceeds this %, reduce all sizes by 50% (8%)
COMPOUNDING_DRAWDOWN_GUARD_PCT=0.08

# ==============================================================
# SECTION 6: ORDER EXECUTION
# ==============================================================
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=GTC
ORDER_TYPE_FALLBACK=GTC
POST_ONLY=true
ORDER_RETRY_ATTEMPTS=3
ORDER_RATE_LIMIT_MS=350
PASSIVE_TICKS=1
IMPROVE_TICKS=1
CROSS_TICKS=0

# ==============================================================
# SECTION 7: ENTRY GUARDS
# ==============================================================
MIN_ENTRY_DEPTH_USD=2
MAX_ENTRY_SPREAD=0.12
MAX_ENTRY_SPREAD_COMBINED_DISCOUNT=0.08
MAX_ENTRY_SPREAD_EXTREME=0.15
MAX_ENTRY_SPREAD_FAIR_VALUE=0.06
MAX_ENTRY_SPREAD_REBALANCE=0.20
ENTRY_IMBALANCE_BLOCK_THRESHOLD=100
MAX_SIGNALS_PER_TICK=2
# Paired arb BUY_YES/BUY_NO legs are treated atomically and are exempt from this cap.
PRICE_MULTIPLIER_LEVELS=0.20:1.65,0.35:1.35,0.50:1.15,0.70:1.00,1.00:0.85
EXIT_BEFORE_END_MS=20000

# ==============================================================
# SECTION: FILL TRACKING (live GTC postOnly orders)
# ==============================================================
# How often to poll CLOB for fill status (ms)
FILL_POLL_INTERVAL_MS=2500
# Stop tracking order after this time (ms) - cancel if unfilled
FILL_POLL_TIMEOUT_MS=120000
# Cancel unfilled orders this many ms before slot end
FILL_CANCEL_BEFORE_END_MS=20000
# Cache USDC balance and allowance checks for this many ms (0 disables caching)
BALANCE_CACHE_TTL_MS=10000
# Legacy fallback for delayed settlement. Runtime now confirms token balances
# before SELL after BUY fills, so this can usually stay at the default.
SELL_AFTER_FILL_DELAY_MS=8000

# ==============================================================
# SECTION 8: BINANCE EDGE
# ==============================================================
BINANCE_EDGE_ENABLED=true
BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt,xrpusdt,dogeusdt,bnbusdt,linkusdt
BINANCE_FLAT_THRESHOLD=0.05
BINANCE_STRONG_THRESHOLD=0.20
BINANCE_BOOST_MULTIPLIER=1.5
BINANCE_REDUCE_MULTIPLIER=0.5
BINANCE_BLOCK_STRONG_CONTRA=true
BINANCE_FV_SENSITIVITY=0.02

# ==============================================================
# SECTION 9: LATENCY & RISK
# ==============================================================
LATENCY_PAUSE_THRESHOLD_MS=2000
LATENCY_RESUME_THRESHOLD_MS=1000
LATENCY_PAUSE_WINDOW_SIZE=10
LATENCY_PAUSE_SAMPLE_TTL_MS=90000
FV_BUY_MAX_PER_SLOT=4
FV_BUY_COOLDOWN_MS=30000
INVENTORY_REBALANCE_FV_BLOCK_MS=60000
BINANCE_FV_DECAY_WINDOW_MS=300000
BINANCE_FV_DECAY_MIN_MULTIPLIER=0.25

# ==============================================================
# SECTION 10: INFRASTRUCTURE
# ==============================================================
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
RPC_URL=https://polygon.drpc.org
POLYMARKET_GEO_TOKEN=
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_REFRESH_MS=1500

# ==============================================================
# SECTION 11: RUNTIME
# ==============================================================
MARKET_SCAN_INTERVAL_MS=2500
MAX_CONCURRENT_MARKETS=6
MARKET_QUERY_LIMIT=80
GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
SIZE_LIQUIDITY_CAP_USD=4000
DEPTH_REFERENCE_SHARES=180
CAPITAL_REFERENCE_SHARES=120

# ==============================================================
# SECTION 12: MONITORING
# ==============================================================
REPORTS_DIR=./reports
LATENCY_LOG=./reports/latency_YYYY-MM-DD.log
STATE_FILE=./reports/state.json
REPORTS_FILE_PREFIX=slot-reports
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIRECTORY=logs
STATUS_CHECK_INTERVAL_MS=300000
AUTO_PAUSE_ON_INCIDENT=true
PAUSE_GRACE_PERIOD_MS=60000

# ==============================================================
# SECTION 13: LOTTERY LAYER (Convex Opposite-Side Tickets)
# ==============================================================
LOTTERY_LAYER_ENABLED=false
LOTTERY_MAX_RISK_USDC=3
LOTTERY_MIN_CENTS=0.03
LOTTERY_MAX_CENTS=0.07
LOTTERY_RELATIVE_PRICING_ENABLED=true
LOTTERY_RELATIVE_PRICE_FACTOR=0.25
LOTTERY_RELATIVE_MAX_CENTS=0.07
LOTTERY_TAKE_PROFIT_MIN_CENTS=0.05
LOTTERY_TAKE_PROFIT_MULTIPLIER=1.15
LOTTERY_EXIT_BEFORE_END_MS=90000
LOTTERY_ONLY_AFTER_SNIPER=true
LOTTERY_MAX_PER_SLOT=1
LOTTERY_STOP_LOSS_PCT=0.50
LOTTERY_MAX_HOLD_MS=150000

# ==============================================================
# SECTION 14: PRODUCT TEST MODE
# ==============================================================
TEST_MIN_TRADE_USDC=1
TEST_MAX_SLOTS=1
