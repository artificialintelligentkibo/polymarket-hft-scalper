# =====================================================================
# MINIMUM RISK OBI CONFIG — Balance ~$50-100
# =====================================================================
# Phase 23 (2026-04-09): safest possible settings for OBI-only trading.
#
# Key principles:
# 1. ONE position at a time (GLOBAL_MAX_EXPOSURE_USD=18)
# 2. Max 25% of balance per trade (OBI_MAX_RISK_PER_TRADE_PCT=0.25)
# 3. Binance alignment REQUIRED (no flat/contra entries)
# 4. All legacy engines DISABLED (OBI is sole entry engine)
# 5. Conservative entry filters (high imbalance, wide price range)
# 6. Minimum share sizes (6 shares = CLOB minimum)
#
# CLOB REALITY: Polymarket minimum = 5 shares + $1 notional.
# At typical OBI prices (30-50¢), minimum position = 6 × 0.50 = $3.
# But practical minimum is ~$15-17 because entry+exit need room.
# This is UNAVOIDABLE — it's the exchange minimum.
# =====================================================================


# =====================================================================
# STRATEGY PRESET — OBI ONLY
# =====================================================================
ACTIVE_STRATEGY=CURRENT_SNIPER

# =====================================================================
# OPERATING MODE — LIVE
# =====================================================================
SIMULATION_MODE=false
TEST_MODE=false
DRY_RUN=false
PRODUCT_TEST_MODE=false
ENABLE_SIGNAL=true
PAPER_TRADING_ENABLED=false

AUTO_REDEEM=true
REDEEM_INTERVAL_MS=30000


# =====================================================================
# DYNAMIC COMPOUNDING
# =====================================================================
COMPOUNDING_ENABLED=true
COMPOUNDING_GLOBAL_EXPOSURE_PCT=0.80
COMPOUNDING_MAX_SLOT_EXPOSURE_PCT=0.50


# =====================================================================
# ALL LEGACY LAYERS — DISABLED
# =====================================================================
# When OBI_ENGINE_ENABLED=true, legacy signals are already skipped
# (Phase 22 guard in index.ts), but we also disable these for safety.
ENTRY_STRATEGY=LEGACY
SNIPER_MODE_ENABLED=false
MARKET_MAKER_MODE=false
DYNAMIC_QUOTING_ENABLED=false
LOTTERY_LAYER_ENABLED=false
PAIRED_ARB_ENABLED=false
PAIRED_ARB_ASYNC_ENABLED=false
LATENCY_MOMENTUM_ENABLED=false
MM_AUTO_ACTIVATE_AFTER_SNIPER=false
MM_AUTONOMOUS_QUOTES=false


# =====================================================================
# OBI ENGINE — MAIN ENTRY ENGINE (minimum risk)
# =====================================================================
OBI_ENGINE_ENABLED=true
OBI_SHADOW_MODE=false

# --- Entry filters (conservative) ---
OBI_THIN_THRESHOLD_USD=8
OBI_MIN_LIQUIDITY_USD=500
OBI_ENTRY_IMBALANCE_RATIO=0.30
OBI_EXIT_REBALANCE_RATIO=0.65

# --- Sizing (MINIMUM = 7 shares to pass dust-safety gate at 0.30) ---
# Phase 23 dust gate: at bestAsk=0.30, need ceil(1.0/0.15)=7 shares min.
# At bestAsk=0.50: 7×0.50=$3.50. At 0.30: 7×0.30=$2.10. Safe for $56 balance.
OBI_ENTRY_SHARES=7
OBI_MAX_POSITION_SHARES=7

# --- Timing ---
OBI_COOLDOWN_MS=15000
OBI_SLOT_WARMUP_MS=5000
OBI_STOP_ENTRY_BEFORE_END_MS=90000
OBI_CANCEL_ALL_BEFORE_END_MS=20000

# --- Price range (30-50¢ = balanced binary markets only) ---
OBI_MIN_ENTRY_PRICE=0.30
OBI_MAX_ENTRY_PRICE=0.50

# --- Exit targets ---
OBI_SCALP_EXIT_EDGE=0.08
OBI_MM_ASK_ENABLED=true
OBI_MM_BID_OPPOSITE_ENABLED=false
OBI_MM_ASK_SPREAD_TICKS=0.015

# --- Safety nets ---
OBI_HARD_STOP_USD=2.0
OBI_MIN_ENTRY_NOTIONAL_USD=3.0
OBI_CLOB_MIN_NOTIONAL_USD=1.0
OBI_CLOB_MIN_SHARES=5
OBI_LOSING_EXIT_COOLDOWN_MS=300000
OBI_LOSING_EXIT_COOLDOWN_BY_COIN_MS=600000
OBI_IMBALANCE_COLLAPSE_RATIO=1.5
OBI_PREFLIGHT_BALANCE_CHECK=true

# --- Binance gate (STRICT — require directional alignment) ---
OBI_BINANCE_GATE_ENABLED=true
OBI_BINANCE_RUNAWAY_ABS_PCT=0.30
OBI_BINANCE_CONTRA_ABS_PCT=0.15
OBI_BINANCE_REQUIRE_ALIGNMENT=true

# --- Compounding (disabled at small balance) ---
OBI_COMPOUND_THRESHOLD_USD=200
OBI_MAX_RISK_PER_TRADE_PCT=0.25

# --- Aggressive entry OFF (limit orders only) ---
OBI_AGGRESSIVE_ENTRY=false


# =====================================================================
# ORDER BOOK IMBALANCE FILTER (legacy gate — keep enabled for reporting)
# =====================================================================
ORDER_BOOK_IMBALANCE_ENABLED=true
OBI_KEEP_STRONGER_LEG_PCT=0.50


# =====================================================================
# GLOBAL RISK — CRITICAL: limits to 1 position at a time
# =====================================================================
# At $56 balance, one OBI entry = ~$3-5 (6 shares × 0.50).
# GLOBAL_MAX_EXPOSURE_USD=18 ensures max 1 position.
# Even if entry is at max price (0.50), 6 shares = $3.
GLOBAL_MAX_EXPOSURE_USD=18
TRAILING_TAKE_PROFIT=0.025
HARD_STOP_LOSS=0.12
HARD_STOP_COOLDOWN_MS=15000
MAX_DRAWDOWN_USDC=-8

MAX_NET_YES=20
MAX_NET_NO=20
INVENTORY_IMBALANCE_THRESHOLD=15
INVENTORY_REBALANCE_FRACTION=0.4


# =====================================================================
# POSITION SIZING — minimum everywhere
# =====================================================================
MIN_SHARES=6
MAX_SHARES=6
BASE_ORDER_SHARES=6


# =====================================================================
# SNIPER LAYER — DISABLED but keep config for reference
# =====================================================================
SNIPER_SLOT_WARMUP_MS=5000
SNIPER_MIN_VELOCITY_PCT_PER_SEC=0.002
SNIPER_MIN_BINANCE_MOVE_PCT=0.035
SNIPER_MAX_CONCURRENT_SAME_DIRECTION=2
SNIPER_BASE_SHARES=6
SNIPER_STRONG_SHARES=6
SNIPER_MAX_POSITION_SHARES=6
SNIPER_MIN_EDGE_AFTER_FEES=0.025
SNIPER_MAX_ENTRY_PRICE=0.40
SNIPER_MIN_ENTRY_PRICE=0.03
SNIPER_MIN_PM_LAG=0.03
SNIPER_COOLDOWN_MS=3000
SNIPER_EXIT_BEFORE_END_MS=30000
SNIPER_STOP_LOSS_PCT=0.06
SNIPER_MAX_HOLD_MS=60000
SNIPER_VOLATILITY_SCALE=0.0045
SNIPER_BREAK_EVEN_EDGE=0.04
SNIPER_SCALP_EXIT_EDGE=0.06


# =====================================================================
# MARKET SELECTION — all crypto coins, 5-min only
# =====================================================================
COINS_TO_TRADE=BTC,ETH,XRP,SOL
FILTER_5MIN_ONLY=true
MIN_LIQUIDITY_USD=500
WHITELIST_CONDITION_IDS=


# =====================================================================
# EV + KELLY
# =====================================================================
EV_KELLY_ENABLED=true
EV_MIN_THRESHOLD=0.005
EV_MIN_THRESHOLD_HIGH_FEE=0.008
KELLY_FRACTION=0.50


# =====================================================================
# ORDER EXECUTION — post-only maker (cheapest fees)
# =====================================================================
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=GTC
ORDER_TYPE_FALLBACK=IOC
POST_ONLY=true
POST_ONLY_ONLY=true
PREFER_MAKER_ORDERS=false
ORDER_RETRY_ATTEMPTS=3
ORDER_RATE_LIMIT_MS=250
PASSIVE_TICKS=1
IMPROVE_TICKS=1
CROSS_TICKS=0


# =====================================================================
# ENTRY GUARDS
# =====================================================================
MIN_ENTRY_DEPTH_USD=2
MAX_ENTRY_SPREAD=0.12
MAX_ENTRY_SPREAD_COMBINED_DISCOUNT=0.10
MAX_ENTRY_SPREAD_EXTREME=0.15
MAX_ENTRY_SPREAD_FAIR_VALUE=0.06
MAX_ENTRY_SPREAD_REBALANCE=0.20
ENTRY_IMBALANCE_BLOCK_THRESHOLD=100
MAX_SIGNALS_PER_TICK=2
PRICE_MULTIPLIER_LEVELS=0.20:1.65,0.35:1.35,0.50:1.15,0.70:1.00,1.00:0.85
EXIT_BEFORE_END_MS=20000


# =====================================================================
# LEGACY ENTRIES (all disabled / unreachable thresholds)
# =====================================================================
MIN_COMBINED_DISCOUNT=0.01
EXTREME_SELL_THRESHOLD=0.92
EXTREME_BUY_THRESHOLD=0.001
FAIR_VALUE_BUY_THRESHOLD=9.99
FAIR_VALUE_SELL_THRESHOLD=9.99


# =====================================================================
# FILL TRACKING
# =====================================================================
FILL_POLL_INTERVAL_MS=2500
FILL_POLL_TIMEOUT_MS=120000
FILL_CANCEL_BEFORE_END_MS=20000
BALANCE_CACHE_TTL_MS=3000
SELL_AFTER_FILL_DELAY_MS=12000


# =====================================================================
# BINANCE EDGE
# =====================================================================
BINANCE_EDGE_ENABLED=true
BINANCE_SYMBOLS=btcusdt,ethusdt,xrpusdt,solusdt
BINANCE_FLAT_THRESHOLD=0.018
BINANCE_STRONG_THRESHOLD=0.20
BINANCE_BOOST_MULTIPLIER=2
BINANCE_REDUCE_MULTIPLIER=0
BINANCE_BLOCK_STRONG_CONTRA=true
BINANCE_FV_SENSITIVITY=0.02


# =====================================================================
# DEEP BINANCE (disabled)
# =====================================================================
DEEP_BINANCE_MODE=false
BINANCE_WS_ENABLED=false


# =====================================================================
# REGIME FILTER (disabled)
# =====================================================================
REGIME_FILTER_ENABLED=false


# =====================================================================
# MONITORING
# =====================================================================
TEST_MIN_TRADE_USDC=1
TEST_MAX_SLOTS=1
STATUS_CHECK_INTERVAL_MS=300000
AUTO_PAUSE_ON_INCIDENT=true
PAUSE_GRACE_PERIOD_MS=60000
REPORTS_DIR=./reports
LATENCY_LOG=./reports/latency_YYYY-MM-DD.log
STATE_FILE=./reports/state.json
REPORTS_FILE_PREFIX=slot-reports
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIRECTORY=logs
MARKET_SCAN_INTERVAL_MS=2500
MAX_CONCURRENT_MARKETS=8
MARKET_QUERY_LIMIT=80
GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
SIZE_LIQUIDITY_CAP_USD=4000
DEPTH_REFERENCE_SHARES=180
CAPITAL_REFERENCE_SHARES=120


# =====================================================================
# INFRASTRUCTURE
# =====================================================================
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
RPC_URL=https://rpc.ankr.com/polygon/05ce7e3030100342821cfcc7d77c0d3bf86191ce072d2995d4f29caaa991b5ee
POLYMARKET_GEO_TOKEN=
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_REFRESH_MS=1500
