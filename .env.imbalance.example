# =====================================================================
# LIVE CONFIG — ACTIVE_STRATEGY=ORDER_BOOK_IMBALANCE (vague-sourdough)
# Balance ~$13, entry size 6 shares, OBI standalone Layer 1/2/3
# =====================================================================
# How to use:
#   1. Copy to .env on the VPS
#   2. Start bot — first run uses OBI_SHADOW_MODE=true (observe only)
#   3. After 30–60 min of shadow logs, flip OBI_SHADOW_MODE=false
#      to start real trading
# =====================================================================


# =====================================================================
# STRATEGY PRESET — auto-configures sniper/binance/paired off
# =====================================================================
# ORDER_BOOK_IMBALANCE preset automatically:
#   - Disables Sniper (Binance-dependent)
#   - Disables Latency Momentum + Paired Arb
#   - Disables Binance edge / WS
#   - Enables ObiEngine (standalone Layer 1)
#   - Enables MARKET_MAKER_MODE + DYNAMIC_QUOTING for Layer 2 follow-ons
#   - Forces POST_ONLY_ONLY=true (maker-only, 0% fee + 25% rebate)
ACTIVE_STRATEGY=ORDER_BOOK_IMBALANCE


# =====================================================================
# OPERATING MODE — LIVE
# =====================================================================
SIMULATION_MODE=false
TEST_MODE=false
DRY_RUN=false
PRODUCT_TEST_MODE=false
ENABLE_SIGNAL=true
PAPER_TRADING_ENABLED=false

AUTO_REDEEM=true
REDEEM_INTERVAL_MS=30000


# =====================================================================
# OBI ENGINE — core standalone entry/exit logic
# =====================================================================
# Master switch (preset sets this to true, but explicit for clarity)
OBI_ENGINE_ENABLED=true

# ⚠️ SHADOW MODE — start with TRUE. The bot will LOG every "would enter"
# and "would exit" decision without sending orders. After you see 10+
# shadow decisions in the logs, flip this to false to start real trading.
OBI_SHADOW_MODE=true

# --- Entry imbalance detection -------------------------------------
# Thin side USD threshold below which we consider the book imbalanced.
# vague-sourdough observed entries happen around $4–$12 on thin side.
OBI_THIN_THRESHOLD_USD=8
# Minimum total top-of-book liquidity required (bid + ask USD).
# Lower this to ~300 if shadow mode produces zero decisions in 30 min.
OBI_MIN_LIQUIDITY_USD=500
# thin / thick ratio ceiling. 0.35 = thin side is at most 35% of thick.
OBI_ENTRY_IMBALANCE_RATIO=0.35

# --- Entry sizing -----------------------------------------------------
# 12 shares * $0.25 = $3 avg per position. Engine auto-sizes UP if price
# is low to keep exit notional above CLOB minimum (avoids dust trap).
OBI_ENTRY_SHARES=12
OBI_MAX_POSITION_SHARES=20

# Entry price band — engine still auto-sizes shares to clear dust.
OBI_MIN_ENTRY_PRICE=0.18
OBI_MAX_ENTRY_PRICE=0.45

# Skip entries below this notional (USD). Stops micro-positions that
# can't be exited cleanly via CLOB.
OBI_MIN_ENTRY_NOTIONAL_USD=3.0
# CLOB minimums (Polymarket platform constants).
OBI_CLOB_MIN_NOTIONAL_USD=1.0
OBI_CLOB_MIN_SHARES=5

# --- Slot timing ---------------------------------------------------
# Don't enter in first 5s (let book settle)
OBI_SLOT_WARMUP_MS=5000
# Stop new entries 90s before slot end (give time for rebalance)
OBI_STOP_ENTRY_BEFORE_END_MS=90000
# Flatten everything 20s before slot end
OBI_CANCEL_ALL_BEFORE_END_MS=20000
# Re-entry cooldown per market
OBI_COOLDOWN_MS=15000

# --- Exit logic ----------------------------------------------------
# Exit when ratio recovers to this value (thin side rebuilds)
OBI_EXIT_REBALANCE_RATIO=0.65
# Keep fraction of stronger leg on rebalance (0 = flatten all)
OBI_KEEP_STRONGER_LEG_PCT=0.50
# Scalp exit at +8% profit from entry
OBI_SCALP_EXIT_EDGE=0.08

# --- Layer 2: MM quoting after fill --------------------------------
# After an OBI entry fills, post a maker ask at entry + spread to
# capture rebate + spread when order book rebalances.
OBI_MM_ASK_ENABLED=true
OBI_MM_ASK_SPREAD_TICKS=0.015
# Hedge on opposite outcome (advanced, leave off for small balance)
OBI_MM_BID_OPPOSITE_ENABLED=false
OBI_MM_BID_OPPOSITE_FACTOR=0.25

# --- Safety ---------------------------------------------------------
# false = passive limit orders only (maker fee 0%)
# true  = will cross spread +1 tick on entry (worse fees, more fills)
OBI_AGGRESSIVE_ENTRY=false

# Hard PnL stop per position (USD). If a position bleeds more than this
# in MTM terms, OBI emits a cross-spread reduceOnly exit immediately.
OBI_HARD_STOP_USD=2.0
# If imbalance flips against us this hard, exit immediately
# (currentRatio = thin/thick). 1.5 = thin became 1.5x the thick side.
OBI_IMBALANCE_COLLAPSE_RATIO=1.5
# Re-entry guard after a losing exit on the same market (ms).
# Prevents averaging down into a losing slot. 5 minutes by default.
OBI_LOSING_EXIT_COOLDOWN_MS=300000
# Refuse to enter if wallet USDC < required notional * 1.05.
# Stops the 562-error retry storm we hit on the $1.70 balance.
OBI_PREFLIGHT_BALANCE_CHECK=true


# =====================================================================
# DYNAMIC COMPOUNDING — generous for small balance
# =====================================================================
COMPOUNDING_ENABLED=true
COMPOUNDING_GLOBAL_EXPOSURE_PCT=0.80
COMPOUNDING_MAX_SLOT_EXPOSURE_PCT=0.50


# =====================================================================
# ACTIVE LAYERS — OBI preset handles these, but explicit for clarity
# =====================================================================
SNIPER_MODE_ENABLED=false
LATENCY_MOMENTUM_ENABLED=false
PAIRED_ARB_ENABLED=false
PAIRED_ARB_ASYNC_ENABLED=false
MARKET_MAKER_MODE=true
DYNAMIC_QUOTING_ENABLED=true
MM_AUTO_ACTIVATE_AFTER_SNIPER=false
LOTTERY_LAYER_ENABLED=false
LAYER_CONFLICT_RESOLUTION=BLOCK


# =====================================================================
# GLOBAL RISK (micro-balance guardrails)
# =====================================================================
GLOBAL_MAX_EXPOSURE_USD=10
HARD_STOP_LOSS=0.20
HARD_STOP_COOLDOWN_MS=15000
MAX_DRAWDOWN_USDC=-6

MAX_NET_YES=40
MAX_NET_NO=40


# =====================================================================
# POSITION SIZING — 6 shares minimum everywhere
# =====================================================================
MIN_SHARES=6
MAX_SHARES=6
BASE_ORDER_SHARES=6


# =====================================================================
# ORDER EXECUTION — post-only maker
# =====================================================================
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=GTC
ORDER_TYPE_FALLBACK=IOC
POST_ONLY=true
POST_ONLY_ONLY=true
PREFER_MAKER_ORDERS=true
ORDER_RETRY_ATTEMPTS=3
ORDER_RATE_LIMIT_MS=250
PASSIVE_TICKS=1
IMPROVE_TICKS=1
CROSS_TICKS=0


# =====================================================================
# MARKET SELECTION — crypto 5-min markets only
# =====================================================================
COINS_TO_TRADE=BTC,ETH,XRP,SOL
FILTER_5MIN_ONLY=true
MIN_LIQUIDITY_USD=500
WHITELIST_CONDITION_IDS=


# =====================================================================
# MM QUOTING — Layer 2 engine (OBI follow-ons)
# =====================================================================
MM_QUOTE_SHARES=6
MM_MAX_QUOTE_SHARES=12
MM_MAKER_MIN_EDGE=0.003
MM_MIN_QUOTE_LIFETIME_MS=1500
MM_REPRICE_DEADBAND_TICKS=2
QUOTING_INTERVAL_MS=1500
MM_MAX_CONCURRENT_MARKETS=3
MM_SLOT_WARMUP_MS=2000
MM_OPENING_SEED_WINDOW_MS=10000
MM_STOP_NEW_ENTRIES_BEFORE_END_MS=90000
MM_CANCEL_ALL_QUOTES_BEFORE_END_MS=15000
MM_TOXIC_FLOW_BLOCK_MOVE_PCT=0.08
MM_TOXIC_FLOW_MICROPRICE_TICKS=1.5
MM_POST_ASK_ONLY_REENTRY_COOLDOWN_MS=15000
MM_GROSS_REENTRY_THRESHOLD_CLIPS=2
MM_POST_SNIPER_GRACE_WINDOW_MS=0
MM_AUTONOMOUS_QUOTES=false


# =====================================================================
# ENTRY GUARDS
# =====================================================================
MIN_ENTRY_DEPTH_USD=2
MAX_ENTRY_SPREAD=0.15
MAX_ENTRY_SPREAD_COMBINED_DISCOUNT=0.10
MAX_ENTRY_SPREAD_EXTREME=0.15
MAX_ENTRY_SPREAD_FAIR_VALUE=0.06
MAX_ENTRY_SPREAD_REBALANCE=0.20
ENTRY_IMBALANCE_BLOCK_THRESHOLD=100
MAX_SIGNALS_PER_TICK=3
PRICE_MULTIPLIER_LEVELS=0.20:1.65,0.35:1.35,0.50:1.15,0.70:1.00,1.00:0.85
EXIT_BEFORE_END_MS=20000


# =====================================================================
# EV + KELLY (light filter)
# =====================================================================
EV_KELLY_ENABLED=true
EV_MIN_THRESHOLD=0.003
EV_MIN_THRESHOLD_HIGH_FEE=0.005
KELLY_FRACTION=0.50


# =====================================================================
# LEGACY ENTRIES (disabled — OBI replaces all of these)
# =====================================================================
ENTRY_STRATEGY=LEGACY
MIN_COMBINED_DISCOUNT=0.01
EXTREME_SELL_THRESHOLD=0.92
EXTREME_BUY_THRESHOLD=0.001
FAIR_VALUE_BUY_THRESHOLD=9.99
FAIR_VALUE_SELL_THRESHOLD=9.99
TRAILING_TAKE_PROFIT=0.025

# Sniper disabled but params kept for safe parsing
SNIPER_BASE_SHARES=6
SNIPER_MAX_POSITION_SHARES=6
SNIPER_MIN_BINANCE_MOVE_PCT=0.99
SNIPER_STRONG_BINANCE_MOVE_PCT=0.99
SNIPER_MIN_EDGE_AFTER_FEES=0.99
SNIPER_MAX_ENTRY_PRICE=0.40
SNIPER_MIN_ENTRY_PRICE=0.03
SNIPER_STOP_LOSS_PCT=0.15
SNIPER_MAX_HOLD_MS=45000

# Lottery disabled (LOTTERY_LAYER_ENABLED=false above), but validator
# requires positive values, so we set tiny placeholders.
LOTTERY_MAX_RISK_USDC=0.01
LOTTERY_MIN_CENTS=0.12
LOTTERY_MAX_CENTS=0.18
LOTTERY_ONLY_AFTER_SNIPER=true
LOTTERY_MAX_PER_SLOT=1


# =====================================================================
# FILL TRACKING
# =====================================================================
FILL_POLL_INTERVAL_MS=2500
FILL_POLL_TIMEOUT_MS=120000
FILL_CANCEL_BEFORE_END_MS=20000
BALANCE_CACHE_TTL_MS=3000
SELL_AFTER_FILL_DELAY_MS=12000


# =====================================================================
# BINANCE EDGE — disabled by OBI preset
# =====================================================================
BINANCE_EDGE_ENABLED=false
BINANCE_WS_ENABLED=false
DEEP_BINANCE_MODE=false
BINANCE_SYMBOLS=btcusdt,ethusdt,xrpusdt,solusdt
BINANCE_FLAT_THRESHOLD=0.018
BINANCE_STRONG_THRESHOLD=0.20
BINANCE_BOOST_MULTIPLIER=1
BINANCE_REDUCE_MULTIPLIER=0
BINANCE_BLOCK_STRONG_CONTRA=false
BINANCE_FV_SENSITIVITY=0.02
BINANCE_DEPTH_LEVELS=20
BINANCE_FUNDING_WEIGHT=0.3
MIN_BINANCE_SPREAD_THRESHOLD=0.004
DYNAMIC_SPREAD_VOL_FACTOR=1.5
BINANCE_FAIR_VALUE_WEIGHT=0.7
POLYMARKET_FAIR_VALUE_WEIGHT=0.2


# =====================================================================
# LATENCY GUARDS
# =====================================================================
LATENCY_PAUSE_THRESHOLD_MS=1500
LATENCY_RESUME_THRESHOLD_MS=1000
LATENCY_PAUSE_WINDOW_SIZE=10
LATENCY_PAUSE_SAMPLE_TTL_MS=90000
FV_BUY_MAX_PER_SLOT=1
FV_BUY_COOLDOWN_MS=45000
INVENTORY_REBALANCE_FV_BLOCK_MS=60000
BINANCE_FV_DECAY_WINDOW_MS=300000
BINANCE_FV_DECAY_MIN_MULTIPLIER=0.25
INVENTORY_IMBALANCE_THRESHOLD=35
INVENTORY_REBALANCE_FRACTION=0.4


# =====================================================================
# FEES (reduced on thin side — taker fee ~0% near $0.05/$0.95)
# =====================================================================
DEFAULT_TAKER_FEE=0.02
HIGH_FEE_TAKER_FEE=0.0315


# =====================================================================
# REGIME FILTER — off for small balance to maximize entries
# =====================================================================
REGIME_FILTER_ENABLED=false
REGIME_FILTER_LOOKBACK_MS=300000
REGIME_FILTER_BAR_INTERVAL_MS=10000
REGIME_FILTER_MIN_SAMPLES=20
REGIME_FILTER_EFFICIENCY_THRESHOLD=0.4
REGIME_FILTER_ATR_THRESHOLD=0.0003


# =====================================================================
# PAIRED ARB (disabled — kept for safe parsing)
# =====================================================================
PAIRED_ARB_MAX_PAIR_COST=0.985
PAIRED_ARB_MIN_NET_EDGE=0.005
PAIRED_ARB_MIN_SHARES=6
PAIRED_ARB_MAX_SHARES=10
PAIRED_ARB_MAX_PER_SIDE=10
PAIRED_ARB_REQUIRE_BOTH_LIQUIDITY=true


# =====================================================================
# MONITORING
# =====================================================================
TEST_MIN_TRADE_USDC=1
TEST_MAX_SLOTS=1
STATUS_CHECK_INTERVAL_MS=300000
AUTO_PAUSE_ON_INCIDENT=true
PAUSE_GRACE_PERIOD_MS=60000
REPORTS_DIR=./reports
LATENCY_LOG=./reports/latency_YYYY-MM-DD.log
STATE_FILE=./reports/state.json
REPORTS_FILE_PREFIX=slot-reports
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIRECTORY=logs
MARKET_SCAN_INTERVAL_MS=2500
MAX_CONCURRENT_MARKETS=8
MARKET_QUERY_LIMIT=80
GRACEFUL_SHUTDOWN_TIMEOUT_MS=12000
SIZE_LIQUIDITY_CAP_USD=4000
DEPTH_REFERENCE_SHARES=180
CAPITAL_REFERENCE_SHARES=120


# =====================================================================
# INFRASTRUCTURE
# =====================================================================
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
RPC_URL=https://rpc.ankr.com/polygon/05ce7e3030100342821cfcc7d77c0d3bf86191ce072d2995d4f29caaa991b5ee
POLYMARKET_GEO_TOKEN=
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
ORDERBOOK_DEPTH_LEVELS=5
ORDERBOOK_REFRESH_MS=1500
